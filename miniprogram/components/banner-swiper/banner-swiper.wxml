<view class="banner-swiper" wx:if="{{banners.length}}">
  <swiper
    class="swiper"
    indicator-dots="{{true}}"
    autoplay="{{true}}"
    circular="{{true}}"
    interval="{{4000}}"
    duration="{{500}}"
    indicator-color="rgba(255,255,255,0.4)"
    indicator-active-color="#ffffff"
  >
    <swiper-item wx:for="{{banners}}" wx:key="id" data-link="{{item.linkUrl}}" bindtap="onTap">
      <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill" lazy-load="{{true}}" />
      <view class="banner-mask" wx:if="{{item.title || item.subtitle}}">
        <text class="banner-title" wx:if="{{item.title}}">{{item.title}}</text>
        <text class="banner-subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</text>
      </view>
    </swiper-item>
  </swiper>
</view>
