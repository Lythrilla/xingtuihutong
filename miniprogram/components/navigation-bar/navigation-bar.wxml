<view class="weui-navigation-bar {{extClass}}">
  <view class="weui-navigation-bar__inner {{ios ? 'ios' : 'android'}} {{blur ? 'is-blur' : ''}} {{theme === 'brand' ? 'is-brand' : ''}}" style="color: {{color}}; background: {{background}}; {{displayStyle}}; {{innerPaddingRight}}; {{safeAreaTop}};">

    <!-- 左侧按钮 -->
    <view class='weui-navigation-bar__left' style="{{leftWidth}};">
      <block wx:if="{{back || homeButton}}">
        <view class="weui-navigation-bar__buttons">
          <view
            wx:if="{{back}}"
            class="nav-btn"
            bindtap="back"
            hover-class="nav-btn--active"
            hover-stay-time="100"
            aria-role="button"
            aria-label="返回"
          >
            <view class="nav-btn__icon nav-btn__icon_goback"></view>
          </view>
          <view
            wx:if="{{homeButton}}"
            class="nav-btn"
            bindtap="home"
            hover-class="nav-btn--active"
            hover-stay-time="100"
            aria-role="button"
            aria-label="首页"
          >
            <view class="nav-btn__icon nav-btn__icon_home"></view>
          </view>
        </view>
      </block>
      <block wx:else>
        <slot name="left"></slot>
      </block>
    </view>

    <!-- 标题 -->
    <view class='weui-navigation-bar__center'>
      <view wx:if="{{loading}}" class="weui-navigation-bar__loading" aria-role="alert">
        <view
          class="weui-loading"
          aria-role="img"
          aria-label="加载中"
        ></view>
      </view>
      <block wx:if="{{title}}">
        <text class="weui-navigation-bar__title">{{title}}</text>
      </block>
      <block wx:else>
        <slot name="center"></slot>
      </block>
    </view>

    <!-- 右侧操作区 -->
    <view class='weui-navigation-bar__right'>
      <slot name="right"></slot>
    </view>
  </view>
</view>
