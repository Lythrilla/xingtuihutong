<view class="tab-shell">
  <view
    wx:for="{{items}}"
    wx:key="key"
    class="tab-item {{active === item.key ? 'active' : ''}} {{item.key === 'match' ? 'match' : ''}}"
    data-item="{{item}}"
    bindtap="navigate"
    hover-class="tab-pressed"
    hover-stay-time="80"
  >
    <view class="tab-active-bg"></view>
    <view wx:if="{{item.key === 'match'}}" class="match-circle">
      <view class="plus-h"></view>
      <view class="plus-v"></view>
    </view>
    <view wx:else class="tab-icon icon-{{item.iconClass}}"></view>
    <text class="tab-label">{{item.label}}</text>
  </view>
</view>
