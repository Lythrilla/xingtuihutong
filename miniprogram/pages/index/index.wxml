<view class="onboarding">
  <view class="hero" style="padding-top: {{statusBarHeight}}px;">
    <view class="hero-spacer" style="height: {{navigationHeight}}px;"></view>
    <view class="brand-title">星推互通</view>
    <view class="brand-subtitle">连接每一个梦想，让更多人听见你的声音</view>
    <image class="hero-image" src="/assets/images/hero.png" mode="aspectFill"></image>
  </view>

  <view class="panel">
    <view class="panel-header">
      <view class="panel-title">请选择您的角色</view>
      <view class="panel-subtitle">我们为您提供专属的服务体验</view>
    </view>

    <view class="role-card provider {{selectedRole === 'provider' ? 'selected' : ''}}" data-role="provider" bindtap="chooseRole" hover-class="pressable">
      <view class="role-info">
        <view class="role-name">我是服务方</view>
        <view class="role-desc">我提供音乐推广、宣发等专业服务</view>
      </view>
      <image class="role-icon" src="/assets/images/role-service.png" mode="aspectFit"></image>
    </view>

    <view class="role-card client {{selectedRole === 'client' ? 'selected' : ''}}" data-role="client" bindtap="chooseRole" hover-class="pressable">
      <view class="role-info">
        <view class="role-name">我是创作者</view>
        <view class="role-desc">我希望宣传我的作品，寻求音乐推广</view>
      </view>
      <image class="role-icon" src="/assets/images/role-client.png" mode="aspectFit"></image>
    </view>

    <checkbox-group class="agreement" bindchange="toggleAgree">
      <label class="agreement-label">
        <checkbox class="agree-native" value="agreed" checked="{{agreed}}"></checkbox>
        <view class="agree-box {{agreed ? 'on' : ''}}">
          <view class="agree-tick" wx:if="{{agreed}}"></view>
        </view>
        <view class="agree-text">已阅读并同意 <text class="link">《用户协议》</text>与<text class="link">《隐私政策》</text></view>
      </label>
    </checkbox-group>
  </view>

  <view wx:if="{{entering}}" class="entering-overlay">
    <view class="entering-spinner"></view>
    <view class="entering-text">正在进入…</view>
  </view>
</view>
