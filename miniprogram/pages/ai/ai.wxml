<view class="page-shell agent-page">
  <page-header title="AI Agent" subtitle="查询数据、调用工具并继续执行"></page-header>

  <data-state loading="{{loading}}" error="{{error}}" bind:action="retry"></data-state>

  <block wx:if="{{!loading && !error}}">
    <view class="agent-hero">
      <view class="hero-grid"></view>
      <view class="agent-orb-wrap">
        <view class="agent-orb-halo"></view>
        <image class="agent-orb" src="/assets/images/ai-orb.webp" mode="aspectFit"></image>
      </view>
      <view class="agent-hero-copy">
        <view class="agent-state"><text></text> AGENT ONLINE</view>
        <view class="agent-title">你的全链路音乐<br />商业智能体</view>
        <view class="agent-engine">{{engine}}</view>
      </view>
      <view class="hero-actions">
        <button bindtap="openInsights">数据洞察 <text>→</text></button>
        <button bindtap="toggleTools">{{showTools ? '收起工具' : tools.length + ' 个工具在线'}}</button>
      </view>
    </view>

    <view class="tool-drawer" wx:if="{{showTools}}">
      <view class="tool-row" wx:for="{{tools}}" wx:key="name">
        <view class="tool-mode {{item.mode}}">{{item.mode === 'read' ? 'Q' : 'A'}}</view>
        <view class="tool-copy">
          <view>{{item.label}}</view>
          <text>{{item.description}}</text>
        </view>
        <view class="tool-ready"></view>
      </view>
    </view>

    <scroll-view
      class="conversation"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      scroll-into-view="{{scrollTarget}}"
    >
      <view wx:for="{{messages}}" wx:key="id" class="message {{item.role}}">
        <view class="message-avatar" wx:if="{{item.role === 'assistant'}}">
          <image src="/assets/images/ai-orb.webp" mode="aspectFit"></image>
        </view>
        <view class="message-body">
          <view class="message-role">{{item.role === 'assistant' ? 'STARCONNECT AGENT' : '你'}}</view>
          <view class="message-content">{{item.content}}</view>
        </view>
      </view>

      <view class="thinking" wx:if="{{thinking}}">
        <image src="/assets/images/ai-orb.webp" mode="aspectFit"></image>
        <view>
          <view>正在规划执行链路</view>
          <text>分析意图 · 选择工具 · 查询实时数据</text>
        </view>
        <view class="thinking-dots"><view></view><view></view><view></view></view>
      </view>

      <view class="execution" wx:if="{{toolCalls.length}}">
        <view class="execution-head">
          <view>
            <text>TOOL CALL TRACE</text>
            <view>执行链路</view>
          </view>
          <text>{{toolCalls.length}} 个工具完成</text>
        </view>
        <view class="trace-item" wx:for="{{toolCalls}}" wx:key="id">
          <view class="trace-axis">
            <view class="trace-dot"></view>
            <view class="trace-line"></view>
          </view>
          <view class="trace-main">
            <view class="trace-name">{{item.label}}</view>
            <view class="trace-code">{{item.name}}</view>
            <view class="trace-meta">
              <text>COMPLETED</text>
              <text>{{item.durationMs}}ms</text>
            </view>
          </view>
        </view>
      </view>

      <view class="artifact-stream" wx:if="{{artifacts.length}}">
        <block wx:for="{{artifacts}}" wx:key="title">
          <view class="artifact">
            <view class="artifact-kicker">{{item.kind === 'action' ? 'ACTION EXECUTED' : 'LIVE DATA'}}</view>
            <view class="artifact-title">{{item.title}}</view>
            <view class="artifact-summary">{{item.summary}}</view>

            <view class="metric-result" wx:if="{{item.kind === 'metrics'}}">
              <view><text>{{item.payload.matches}}</text><label>匹配</label></view>
              <view><text>{{item.payload.conversations}}</text><label>会话</label></view>
              <view><text>{{item.payload.savedPlans}}</text><label>收藏</label></view>
              <view><text>{{item.payload.revenueDisplay}}</text><label>收益</label></view>
            </view>

            <view class="funnel-result" wx:elif="{{item.kind === 'funnel'}}">
              <view wx:for="{{item.funnel}}" wx:key="label" wx:for-item="stage">
                <view class="funnel-label"><text>{{stage.label}}</text><text>{{stage.value}}</text></view>
                <view class="funnel-track"><view style="width: {{stage.width}}%"></view></view>
              </view>
            </view>

            <view class="partner-result" wx:elif="{{item.kind === 'partners'}}">
              <view
                class="partner-line"
                wx:for="{{item.payload.partners}}"
                wx:key="id"
                wx:for-item="partner"
                data-id="{{partner.id}}"
                bindtap="openPartner"
              >
                <view class="partner-rank">{{$index + 1}}</view>
                <view class="partner-copy">
                  <view>{{partner.name}} <text>{{partner.matchScore}}%</text></view>
                  <text>{{partner.identity}} · {{partner.description}}</text>
                </view>
                <view class="partner-arrow">›</view>
              </view>
            </view>

            <scroll-view class="plan-result" wx:elif="{{item.kind === 'plans'}}" scroll-x enhanced show-scrollbar="{{false}}">
              <view class="plan-strip">
                <view class="plan-item" wx:for="{{item.payload.plans}}" wx:key="id" wx:for-item="plan">
                  <view class="plan-score">{{plan.score}}%</view>
                  <view class="plan-name">{{plan.title}}</view>
                  <view class="plan-type">{{plan.planType}}</view>
                  <view class="plan-budget">{{plan.budget}}</view>
                </view>
              </view>
            </scroll-view>

            <button class="action-result" wx:elif="{{item.kind === 'action'}}" bindtap="openMessages">
              已完成 · 前往消息中心
            </button>
          </view>
        </block>
      </view>

      <view class="suggestions" wx:if="{{!thinking && suggestions.length}}">
        <view class="suggestion-title">继续追问</view>
        <button
          wx:for="{{suggestions}}"
          wx:key="*this"
          data-value="{{item}}"
          bindtap="useSuggestion"
        >{{item}} <text>↗</text></button>
      </view>
      <view id="conversation-end" class="conversation-end"></view>
    </scroll-view>
  </block>
</view>

<view class="agent-composer" wx:if="{{!loading && !error}}">
  <input
    value="{{input}}"
    disabled="{{thinking}}"
    maxlength="240"
    confirm-type="send"
    placeholder="告诉 Agent 你的目标，或让它查询数据…"
    bindinput="updateInput"
    bindconfirm="send"
  />
  <button disabled="{{thinking || !input}}" bindtap="send">
    <text wx:if="{{!thinking}}">↑</text>
    <view wx:else class="composer-loader"></view>
  </button>
</view>
<tab-bar active="match"></tab-bar>
