<view class="page-shell agent-page">
  <page-header
    title="{{isCreator ? '创作者 AI Agent' : '推广方 AI Agent'}}"
    subtitle="{{isCreator ? '分析作品、寻找推广方并生成可执行方案' : '分析项目、发现创作者并推进合作'}}"
  ></page-header>

  <data-state loading="{{loading}}" error="{{error}}" bind:action="retry"></data-state>

  <block wx:if="{{!loading && !error}}">
    <view class="agent-intro">
      <view class="hero-grid"></view>
      <view class="hero-orb-wrap">
        <view class="hero-orb-halo"></view>
        <image class="hero-orb" src="/assets/images/ai-illustration.png" mode="aspectFit"></image>
      </view>
      <view class="hero-copy">
        <view class="hero-title">
          <text>{{isCreator ? '让作品推广更清晰' : '让合作判断更高效'}}</text>
          <text>{{isCreator ? '从分析到对接都能交给 AI' : '从发现到跟进都能交给 AI'}}</text>
        </view>
        <view class="hero-desc">{{isCreator ? '作品分析 · 推广方推荐 · 方案规划' : '项目分析 · 创作者推荐 · 合作跟进'}}</view>
      </view>
    </view>

    <view class="agent-shortcuts">
      <button wx:if="{{isCreator}}" bindtap="openMatch">发布推广需求</button>
      <button bindtap="openPlaza">{{isCreator ? '浏览推广方' : '浏览创作者'}}</button>
      <button bindtap="openAnalytics">查看合作数据</button>
    </view>

    <view class="agent-capabilities">
      <view
        wx:for="{{quickActions}}"
        wx:key="title"
        class="capability-row"
        data-value="{{item.prompt}}"
        bindtap="selectSuggestion"
      >
        <view>
          <view>{{item.title}}</view>
          <text>{{item.description}}</text>
        </view>
        <text>立即执行 →</text>
      </view>
    </view>

    <scroll-view
      class="conversation"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      scroll-into-view="{{scrollTarget}}"
    >
      <view wx:for="{{messages}}" wx:key="id" class="message {{item.role}}">
        <view class="message-avatar" wx:if="{{item.role === 'assistant'}}">
          <image src="/assets/images/ai-illustration.png" mode="aspectFit"></image>
        </view>
        <view class="message-body">
          <view class="message-role">{{item.role === 'assistant' ? '星链智能体' : '你'}}</view>
          <view class="message-content">{{item.content}}</view>
        </view>
      </view>

      <view class="thinking" wx:if="{{thinking}}">
        <image src="/assets/images/ai-illustration.png" mode="aspectFit"></image>
        <view>
          <view>正在思考与规划</view>
          <text>理解需求 · 检索数据 · 生成方案</text>
        </view>
        <view class="thinking-dots"><view></view><view></view><view></view></view>
      </view>

      <view class="inline-trace" wx:if="{{toolCalls.length}}">
        <scroll-view class="trace-scroll" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="trace-track">
            <view class="trace-node {{item.status}}" wx:for="{{toolCalls}}" wx:key="id">
              <view class="node-dot"></view>
              <text>{{item.label}}</text>
              <view class="node-line" wx:if="{{index !== toolCalls.length - 1}}"></view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="artifact-stream" wx:if="{{artifacts.length}}">
        <block wx:for="{{artifacts}}" wx:key="title">
          <view class="artifact">
            <view class="artifact-kicker">{{item.kind === 'action' ? '执行结果' : item.kind === 'error' ? '提示' : '分析数据'}}</view>
            <view class="artifact-title">{{item.title}}</view>
            <view class="artifact-summary">{{item.summary}}</view>

            <view class="metric-result" wx:if="{{item.kind === 'metrics'}}">
              <view><text>{{item.payload.matches}}</text><label>匹配</label></view>
              <view><text>{{item.payload.conversations}}</text><label>会话</label></view>
              <view><text>{{item.payload.savedPlans}}</text><label>收藏</label></view>
              <view><text>{{item.payload.revenueDisplay}}</text><label>收益</label></view>
            </view>

            <view class="funnel-result" wx:elif="{{item.kind === 'funnel'}}">
              <view wx:for="{{item.funnel}}" wx:key="label" wx:for-item="stage">
                <view class="funnel-label"><text>{{stage.label}}</text><text>{{stage.value}}</text></view>
                <view class="funnel-track"><view style="width: {{stage.width}}%"></view></view>
              </view>
            </view>

            <view class="partner-result" wx:elif="{{item.kind === 'partners'}}">
              <view
                class="partner-line"
                wx:for="{{item.payload.partners}}"
                wx:key="id"
                wx:for-item="partner"
                data-id="{{partner.id}}"
                bindtap="openPartner"
              >
                <view class="partner-avatar">{{partner.name[0]}}</view>
                <view class="partner-copy">
                  <view>{{partner.name}} <text>{{partner.matchScore}}% 契合度</text></view>
                  <text>{{partner.identity}} · {{partner.description}}</text>
                </view>
              </view>
            </view>

            <scroll-view class="plan-result" wx:elif="{{item.kind === 'plans'}}" scroll-x enhanced show-scrollbar="{{false}}">
              <view class="plan-strip">
                <view class="plan-item" wx:for="{{item.payload.plans}}" wx:key="id" wx:for-item="plan">
                  <view class="plan-score">{{plan.score}}%</view>
                  <view class="plan-name">{{plan.title}}</view>
                  <view class="plan-type">{{plan.planType}}</view>
                  <view class="plan-budget">{{plan.budget}}</view>
                </view>
              </view>
            </scroll-view>

            <view class="error-result" wx:elif="{{item.kind === 'error'}}">可调整条件后重新执行，已完成的结果不会丢失。</view>

            <button
              class="action-result"
              wx:elif="{{item.kind === 'action' && item.actionNavigable}}"
              data-conversation-id="{{item.payload.conversationId}}"
              data-partner-name="{{item.payload.partnerName}}"
              bindtap="openAction"
            >{{item.actionLabel}}</button>
            <view class="action-result static" wx:elif="{{item.kind === 'action'}}">{{item.actionLabel}}</view>
          </view>
        </block>
      </view>

      <view class="suggestions" wx:if="{{!thinking && suggestions.length}}">
        <view class="suggestion-title">继续追问</view>
        <button
          wx:for="{{suggestions}}"
          wx:key="*this"
          data-value="{{item}}"
          bindtap="useSuggestion"
        >{{item}} <text>↗</text></button>
      </view>
      <view id="conversation-end" class="conversation-end"></view>
    </scroll-view>
  </block>
</view>

<view class="agent-composer" wx:if="{{!loading && !error}}">
  <input
    value="{{input}}"
    disabled="{{thinking}}"
    maxlength="240"
    confirm-type="send"
    placeholder="告诉智能体你的目标，或让它查询数据…"
    bindinput="updateInput"
    bindconfirm="send"
  />
  <button disabled="{{thinking || !input}}" bindtap="send">
    <view wx:if="{{!thinking}}" class="ui-icon icon-send"></view>
    <view wx:else class="composer-loader"></view>
  </button>
</view>
<tab-bar active="match"></tab-bar>
