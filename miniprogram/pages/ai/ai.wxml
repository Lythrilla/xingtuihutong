<view class="page-shell ai-page">
  <page-header title="AI 智能推荐" subtitle="让每次合作都有数据与灵感支撑"></page-header>

  <data-state loading="{{loading}}" error="{{error}}" bind:action="retry"></data-state>

  <block wx:if="{{!loading && !error}}">
  <view class="hero">
    <view class="hero-copy">
      <view class="hero-kicker">STARCONNECT AI</view>
      <view class="hero-title">找到此刻最值得合作的人</view>
      <view class="hero-desc">根据当前在架方案与真实合作数据动态推荐</view>
    </view>
    <view class="hero-visual">
      <image class="hero-image" src="/assets/images/ai-orb.png" mode="aspectFit"></image>
    </view>
  </view>

  <view class="tabs" wx:if="{{tabs.length > 1}}">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab {{activeTab === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="changeTab"
    >
      {{item.label}}
    </view>
  </view>

  <view class="ai-insight" wx:if="{{plans.length}}">
    <view class="insight-icon"><view class="ui-icon icon-spark"></view></view>
    <view class="insight-copy">
      <view class="insight-title">{{insightTitle}}</view>
      <view class="insight-desc">{{insightDescription}}</view>
    </view>
  </view>

  <view class="plan-list" wx:if="{{plans.length}}">
    <view class="plan card" wx:for="{{plans}}" wx:key="id">
      <view class="plan-head">
        <view class="plan-icon {{item.colorClass}}">
          <view class="ui-icon icon-{{item.iconClass}}"></view>
        </view>
        <view class="plan-name">
          <view class="plan-title">{{item.title}}</view>
          <view class="plan-type">{{item.planType}}</view>
        </view>
        <view class="plan-score">
          <text>{{item.score}}</text>
          <view>匹配度</view>
        </view>
      </view>
      <view class="plan-desc">{{item.description}}</view>
      <view class="plan-tags">
        <text wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
      </view>
      <view class="plan-foot">
        <view>
          <view class="budget-label">建议预算</view>
          <view class="budget-value">{{item.budget}}</view>
        </view>
        <button
          class="plan-button {{item.saved ? 'saved' : ''}}"
          data-id="{{item.id}}"
          disabled="{{item.saved || savingId !== ''}}"
          loading="{{savingId === item.id}}"
          bindtap="viewPlan"
        >{{item.saved ? '已收藏' : (savingId === item.id ? '收藏中' : '收藏方案')}}</button>
      </view>
    </view>
  </view>

  <data-state
    wx:else
    empty="{{true}}"
    empty-title="暂无可用推荐"
    empty-description="完成一次推广匹配，或稍后等待新方案上线"
    action-text="去推广匹配"
    bind:action="openMatch"
  ></data-state>

  <button class="refresh" wx:if="{{plans.length}}" disabled="{{refreshing}}" bindtap="refresh">
    <view class="ui-icon icon-refresh"></view>
    <text>{{refreshing ? '正在更新' : refreshText}}</text>
  </button>
  </block>
</view>
<tab-bar active="match"></tab-bar>
