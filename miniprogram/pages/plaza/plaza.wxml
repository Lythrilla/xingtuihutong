<view class="page-shell">
  <page-header
    title="{{isCreator ? '找推广方' : '发现创作者'}}"
    subtitle="{{isCreator ? '这里只展示审核通过的推广服务方' : '这里只展示审核通过的创作者与作品'}}"
  ></page-header>

  <data-state loading="{{loading}}" error="{{error}}" bind:action="retry"></data-state>

  <block wx:if="{{!loading && !error}}">
    <view class="plaza-tabs">
      <view class="plaza-tab active">
        <text>{{isCreator ? '推广服务' : '创作者项目'}}</text>
        <view class="tab-line"></view>
      </view>
    </view>

    <view class="search">
      <view class="ui-icon icon-search search-icon"></view>
      <input
        value="{{query}}"
        placeholder="{{isCreator ? '搜索推广能力、渠道或团队' : '搜索创作者、风格或作品方向'}}"
        placeholder-class="placeholder"
        confirm-type="search"
        bindinput="updateSearch"
      ></input>
      <button wx:if="{{query}}" class="search-clear" bindtap="clearSearch" aria-label="清空搜索">×</button>
    </view>

    <view class="discovery-line">
      <view class="discovery-copy">
        <view class="discovery-title">已审核 {{visibleEntries.length}} 位{{isCreator ? '推广方' : '创作者'}}</view>
        <view class="discovery-desc">{{isCreator ? '按服务能力、预算与合作表现排序' : '按作品方向、受众与合作意愿排序'}}</view>
      </view>
      <view class="discovery-actions">
        <button
          class="favorite-filter {{favoritesOnly ? 'active' : ''}}"
          bindtap="toggleFavoritesOnly"
        >{{favoritesOnly ? '只看收藏' : '收藏'}}</button>
        <button
          class="sort-button {{activeType === 'latest' ? 'active' : ''}}"
          disabled="{{listLoading}}"
          bindtap="toggleLatest"
        >{{activeType === 'latest' ? '最新发布' : '智能排序'}}⌄</button>
      </view>
    </view>

    <view class="entry-list" wx:if="{{!listLoading && visibleEntries.length}}">
      <view
        class="entry {{focusedPartnerId === item.id ? 'focused' : ''}}"
        wx:for="{{visibleEntries}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="openDetail"
        hover-class="entry-press"
      >
        <view class="entry-cover">
          <view class="avatar {{item.avatarClass}}">{{item.avatar}}</view>
          <view class="match-badge" wx:if="{{item.matchScore}}">匹配 {{item.matchScore}}%</view>
        </view>
        <view class="entry-main">
          <view class="entry-service">{{item.description}}</view>
          <view class="tag-row">
            <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
          </view>
          <view class="entry-user">
            <view class="user-info">
              <view class="user-name">{{item.name}}</view>
              <view class="verified" wx:if="{{item.matchScore >= 85}}"><view class="verify-dot">✓</view></view>
            </view>
            <button
              class="favorite-button {{item.favorite ? 'active' : ''}}"
              data-id="{{item.id}}"
              catchtap="toggleFavorite"
              aria-label="{{item.favorite ? '取消收藏' : '收藏'}}"
            >{{item.favorite ? '♥' : '♡'}}</button>
          </view>
          <view class="entry-action">
            <button
              class="connect-button"
              data-id="{{item.id}}"
              catchtap="openDetail"
            >{{!canConnect ? '查看公开资料' : isCreator ? '查看并联系' : '查看创作者'}}</button>
          </view>
        </view>
      </view>
    </view>
    <data-state wx:elif="{{listLoading}}" loading="{{true}}"></data-state>
    <data-state
      wx:else
      empty="{{true}}"
      empty-title="{{query ? '没有匹配结果' : favoritesOnly ? '还没有收藏伙伴' : isCreator ? '暂无已审核推广方' : '暂无已审核创作者'}}"
      empty-description="{{query ? '换个名称或标签试试' : favoritesOnly ? '返回广场发现值得合作的人' : '新入驻资料审核通过后才会在这里展示'}}"
      action-text="{{query ? '清空搜索' : favoritesOnly ? '查看全部' : '重新加载'}}"
      bind:action="handleEmptyAction"
    ></data-state>

    <view class="ai-invite" bindtap="openAI" hover-class="pressable">
      <view class="ai-invite-glow"></view>
      <image class="ai-invite-orb" src="/assets/images/ai-illustration.png" mode="aspectFit"></image>
      <view class="ai-invite-copy">
        <view>{{isCreator ? '需要 AI 帮你规划作品推广？' : '需要梳理合作机会？'}}</view>
        <text>{{isCreator ? '分析作品、筛选推广方，再决定如何发布需求' : '让 AI 帮你分析创作者项目与合作重点'}}</text>
      </view>
      <view class="ai-invite-arrow">→</view>
    </view>
  </block>
</view>
<tab-bar active="plaza"></tab-bar>
