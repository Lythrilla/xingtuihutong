<view class="page-shell">
  <page-header title="我的主页" subtitle="{{isProvider ? '管理服务能力与创作者合作' : '管理作品资料与推广合作'}}"></page-header>

  <data-state loading="{{loading}}" error="{{error}}" bind:action="retry"></data-state>

  <block wx:if="{{!loading && !error}}">
    <!-- 头部卡片（参照首页 hero-card） -->
    <view class="hero-card profile-hero-card">
      <view class="hero-grid"></view>
      <!-- 保留首页风格的旋转光晕，放大作为氛围背景 -->
      <view class="hero-orb-wrap" style="top: -60rpx; right: -80rpx; width: 320rpx; height: 320rpx; opacity: 0.5;">
        <view class="hero-orb-halo"></view>
      </view>

      <view class="profile-head">
        <view class="profile-avatar">{{user.avatar}}</view>
        <view class="profile-main">
          <view class="profile-name">{{user.organization}}</view>
          <view class="profile-role">
            <view class="role-check" wx:if="{{user.verified}}">✓</view>
            <text>{{roleLabel}} · {{user.onboardingStatus === 'approved' ? '入驻已通过' : user.onboardingStatus === 'pending' ? '入驻审核中' : '资料待完善'}}</text>
          </view>
        </view>
        <view class="edit-btn" bindtap="editProfile">入驻资料</view>
      </view>
      <view class="profile-desc">{{user.description || '介绍一下自己的业务方向和合作偏好～'}}</view>
      <view class="profile-stats">
        <view class="profile-stat" wx:for="{{stats}}" wx:key="label">
          <text>{{item.value}}</text>
          <view>{{item.label}}</view>
        </view>
      </view>
    </view>

    <!-- 四大金刚功能区（恢复原样） -->
    <view class="workspace">
      <view
        class="workspace-item"
        wx:for="{{quickActions}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="openQuickAction"
        hover-class="pressable"
      >
        <view class="workspace-icon">
          <view class="ui-icon icon-{{item.icon}}"></view>
          <view wx:if="{{item.key === 'agent'}}" class="workspace-spark"></view>
        </view>
        <text>{{item.label}}</text>
      </view>
    </view>

    <!-- 钱包黑金卡片 -->
    <view wx:if="{{isProvider}}" class="wallet-card">
      <view class="wallet-bg"></view>
      <view class="wallet-content">
        <view class="wallet-left">
          <view class="wallet-title"><view class="ui-icon icon-wallet"></view> 可提现余额</view>
          <view class="wallet-amount"><text class="currency">¥</text>{{walletBalance}}</view>
        </view>
        <button class="btn-primary" style="margin-top: 24rpx !important; height: 64rpx !important; border-radius: 32rpx !important; width: 140rpx !important;" disabled="{{actionLoading || walletBalanceCents <= 0}}" bindtap="withdraw">去提现</button>
      </view>
    </view>

    <!-- 能力与认证 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">{{isProvider ? '服务能力' : '作品与风格'}}</text>
        <text class="section-action" bindtap="editProfile">入驻资料 ></text>
      </view>
      <view class="profile-card">
        <view class="certs" wx:if="{{certifications.length}}">
          <view class="cert" wx:for="{{certifications}}" wx:key="id">
            <view class="cert-icon {{item.colorClass}}">
              <view class="ui-icon icon-{{item.iconClass}}"></view>
            </view>
            <text class="cert-title">{{item.title}}</text>
            <view class="cert-status">{{item.status}}</view>
          </view>
        </view>
        <view wx:else class="inline-empty">暂无认证信息</view>
        
        <view class="skill-line" wx:if="{{tags.length}}">
          <text wx:for="{{tags}}" wx:key="*this">{{item}}</text>
        </view>
        <view wx:else class="skill-empty" bindtap="editProfile">+ 添加{{isProvider ? '能力' : '风格'}}标签，让推荐更准确</view>
      </view>
    </view>

    <!-- 精选案例 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">{{isProvider ? '精选案例' : '代表作品'}}</text>
        <text class="section-action">全部案例 ></text>
      </view>
      <scroll-view wx:if="{{cases.length}}" class="case-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="cases">
          <view class="case-card {{item.colorClass}}" wx:for="{{cases}}" wx:key="id">
            <view class="case-type">{{item.caseType}}</view>
            <view class="case-name">{{item.name}}</view>
            <view class="case-result">{{item.resultText}}</view>
          </view>
        </view>
      </scroll-view>
      <view wx:else class="profile-card inline-empty">暂无{{isProvider ? '精选案例' : '代表作品资料'}}</view>
    </view>

    <!-- 更多服务 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">更多服务</text>
      </view>
      <view class="profile-card">
        <view class="service-list">
          <view
            class="service-row"
            wx:for="{{serviceActions}}"
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="openServiceAction"
            hover-class="pressable"
          >
            <view class="service-icon"><view class="ui-icon icon-{{item.icon}}"></view></view>
            <view class="service-copy">
              <view>{{item.label}}</view>
              <text>{{item.description}}</text>
            </view>
            <view class="service-value" wx:if="{{item.key === 'onboarding'}}">{{user.onboardingStatus === 'approved' ? '已通过' : user.onboardingStatus === 'pending' ? '审核中' : '待完善'}}</view>
            <view class="service-arrow">›</view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
<tab-bar active="profile"></tab-bar>

<view wx:if="{{sheetMode}}" class="sheet-layer" bindtap="closeSheet">
  <view class="sheet-card" catchtap="preventClose">
    <view class="sheet-head">
      <view>
        <view class="sheet-title">{{sheetMode === 'edit' ? (isProvider ? '编辑服务方主页' : '编辑创作者主页') : '申请提现'}}</view>
        <view class="sheet-description">
          {{sheetMode === 'edit' ? '完整资料能帮助合作伙伴更快了解你' : '提交后会生成一条待处理结算记录'}}
        </view>
      </view>
      <button class="sheet-close" disabled="{{actionLoading}}" bindtap="closeSheet">×</button>
    </view>

    <block wx:if="{{sheetMode === 'edit'}}">
      <label class="field">
        <text>{{isProvider ? '团队或品牌名称' : '创作者名 / 艺名'}}</text>
        <input
          value="{{organizationInput}}"
          maxlength="40"
          placeholder="{{isProvider ? '请输入对外展示的团队名称' : '请输入对外展示的创作者名称'}}"
          bindinput="updateOrganization"
        />
      </label>
      <label class="field">
        <text>{{isProvider ? '服务简介' : '创作者简介'}}</text>
        <textarea
          value="{{descriptionInput}}"
          maxlength="240"
          placeholder="{{isProvider ? '介绍服务方向、渠道与合作偏好' : '介绍作品方向、受众与合作偏好'}}"
          bindinput="updateDescription"
        ></textarea>
        <view class="field-hint">{{descriptionInput.length}} / 240</view>
      </label>
      <label class="field">
        <text>{{isProvider ? '能力标签' : '风格标签'}}</text>
        <input
          value="{{tagsInput}}"
          maxlength="100"
          placeholder="用逗号分隔，最多 8 个"
          bindinput="updateTags"
        />
      </label>
      <button
        class="btn-primary"
        style="margin-top: 36rpx !important;"
        disabled="{{actionLoading}}"
        loading="{{actionLoading}}"
        bindtap="saveProfile"
      >{{actionLoading ? '保存中' : '保存资料'}}</button>
    </block>

    <block wx:else>
      <view class="balance-summary">
        <view>可提现余额</view>
        <text>{{walletBalance}}</text>
      </view>
      <label class="field">
        <text>提现金额（元）</text>
        <view class="amount-input">
          <text>¥</text>
          <input
            value="{{withdrawInput}}"
            type="digit"
            placeholder="0.00"
            bindinput="updateWithdraw"
          />
          <button bindtap="fillAllBalance">全部</button>
        </view>
      </label>
      <button
        class="btn-primary"
        style="margin-top: 36rpx !important;"
        disabled="{{actionLoading || !withdrawInput}}"
        loading="{{actionLoading}}"
        bindtap="submitWithdrawal"
      >{{actionLoading ? '提交中' : '确认提现'}}</button>
    </block>
  </view>
</view>
