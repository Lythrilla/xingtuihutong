<view class="page-shell profile-page">
  <page-header title="我的主页" subtitle="完善档案，让优质合作主动找到你"></page-header>

  <view class="profile-card">
    <view class="profile-head">
      <view class="profile-avatar">{{user.avatar}}</view>
      <view class="profile-main">
        <view class="profile-name">{{user.organization}}</view>
        <view class="profile-role">
          <view class="role-check" wx:if="{{user.verified}}">✓</view>
          {{user.verified ? '已认证' : '未认证'}}{{roleLabel}}
        </view>
      </view>
      <button class="edit-button" bindtap="editProfile">编辑</button>
    </view>
    <view class="profile-desc">{{user.description}}</view>
    <view class="profile-stats">
      <view class="profile-stat" wx:for="{{stats}}" wx:key="label">
        <text>{{item.value}}</text>
        <view>{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">资质认证</text>
    </view>
    <view class="certs card">
      <view class="cert" wx:for="{{certifications}}" wx:key="id">
        <view class="cert-icon {{item.colorClass}}"><view class="ui-icon icon-{{item.iconClass}}"></view></view>
        <text>{{item.title}}</text>
        <view>{{item.status}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">能力标签</text>
    </view>
    <view class="skill-card card">
      <text wx:for="{{tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">精选案例</text>
    </view>
    <scroll-view class="case-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="cases">
        <view class="case-card {{item.colorClass}}" wx:for="{{cases}}" wx:key="id">
          <view class="case-type">{{item.caseType}}</view>
          <view class="case-name">{{item.name}}</view>
          <view class="case-result">{{item.resultText}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">结算信息</text>
    </view>
    <view class="wallet card">
      <view class="wallet-icon"><view class="ui-icon icon-wallet"></view></view>
      <view class="wallet-main">
        <view class="wallet-label">可提现余额</view>
        <view class="wallet-value">{{walletBalance}}</view>
      </view>
      <button class="wallet-button" bindtap="withdraw">提现</button>
    </view>
  </view>

  <button class="role-switch" bindtap="switchRole">
    切换为{{isProvider ? '被服务方' : '服务方'}}
  </button>
</view>
<tab-bar active="profile"></tab-bar>
