<view class="page-shell">
  <page-header title="消息" subtitle="合作沟通与平台通知都在这里"></page-header>

  <data-state loading="{{loading}}" error="{{error}}" bind:action="retry"></data-state>

  <block wx:if="{{!loading && !error}}">
    <!-- 平台通知模块 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">平台通知</text>
        <button
          wx:if="{{hasUnread}}"
          class="section-action read-action"
          disabled="{{markingRead}}"
          bindtap="markAllRead"
        >{{markingRead ? '处理中' : '全部已读'}}</button>
      </view>

      <view class="notice-list" wx:if="{{notices.length}}">
        <view class="notice-card {{item.isRead ? 'read' : ''}}" wx:for="{{notices}}" wx:key="id">
          <view class="notice-icon-wrap">
            <view class="notice-icon {{item.iconClass}}">
              <view class="ui-icon icon-{{item.icon}}"></view>
            </view>
            <view wx:if="{{!item.isRead}}" class="notice-unread-badge"></view>
          </view>
          
          <view class="notice-main">
            <view class="notice-header">
              <text class="notice-title">{{item.title}}</text>
              <text class="notice-time">{{item.time}}</text>
            </view>
            <view class="notice-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>
      
      <!-- 极简无阴影空状态 -->
      <view wx:else class="empty-state-clean">
        <view class="ui-icon icon-message empty-icon"></view>
        <text>暂无新的平台通知</text>
      </view>
    </view>

    <!-- 合作会话模块 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">合作会话</text>
      </view>

      <view class="chat-list" wx:if="{{chats.length}}">
        <view class="chat-card" wx:for="{{chats}}" wx:key="id" data-id="{{item.id}}" data-name="{{item.name}}" bindtap="openChat">
          <view class="chat-avatar-wrap">
            <view class="chat-avatar {{item.avatarClass}}">{{item.avatar}}</view>
            <view class="chat-unread-badge" wx:if="{{item.unread > 0}}">{{item.unread}}</view>
          </view>
          
          <view class="chat-main">
            <view class="chat-header">
              <text class="chat-name">{{item.name}}</text>
              <text class="chat-time">{{item.time}}</text>
            </view>
            <view class="chat-preview">
              <text class="chat-message">{{item.message}}</text>
              <view class="chat-arrow">
                <view class="ui-icon icon-chevron-right"></view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 原有空状态组件，稍作修改融入背景 -->
      <data-state
        wx:else
        empty="{{true}}"
        empty-title="还没有合作会话"
        empty-description="在合作广场找到合适伙伴后，可以直接开始沟通"
        action-text="去合作广场"
        bind:action="openPlaza"
      ></data-state>
    </view>
  </block>
</view>
<tab-bar active="messages"></tab-bar>
