<view class="page-shell messages-page">
  <page-header title="消息" subtitle="合作沟通与平台通知都在这里"></page-header>

  <data-state loading="{{loading}}" error="{{error}}" bind:action="retry"></data-state>

  <block wx:if="{{!loading && !error}}">
  <view class="section">
    <view class="section-head">
      <text class="section-title">平台通知</text>
      <button
        wx:if="{{hasUnread}}"
        class="section-action read-action"
        disabled="{{markingRead}}"
        bindtap="markAllRead"
      >{{markingRead ? '处理中' : '全部已读'}}</button>
    </view>
    <view class="notice-list card" wx:if="{{notices.length}}">
      <view class="notice {{item.isRead ? 'read' : ''}}" wx:for="{{notices}}" wx:key="id">
        <view class="notice-icon {{item.iconClass}}">
          <view class="ui-icon icon-{{item.icon}}"></view>
        </view>
        <view class="notice-main">
          <view class="notice-line">
            <view class="notice-title-line">
              <view wx:if="{{!item.isRead}}" class="unread-dot"></view>
              <text class="notice-title">{{item.title}}</text>
            </view>
            <text class="notice-time">{{item.time}}</text>
          </view>
          <view class="notice-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>
    <view wx:else class="card inline-empty">暂无平台通知</view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">合作会话</text>
    </view>
    <view class="chat-list card" wx:if="{{chats.length}}">
      <view class="chat" wx:for="{{chats}}" wx:key="id" data-id="{{item.id}}" data-name="{{item.name}}" bindtap="openChat">
        <view class="chat-avatar {{item.avatarClass}}">{{item.avatar}}</view>
        <view class="chat-main">
          <view class="chat-line">
            <text class="chat-name">{{item.name}}</text>
            <text class="chat-time">{{item.time}}</text>
          </view>
          <view class="chat-line">
            <text class="chat-message">{{item.message}}</text>
            <view class="chat-unread" wx:if="{{item.unread > 0}}">{{item.unread}}</view>
          </view>
        </view>
      </view>
    </view>
    <data-state
      wx:else
      empty="{{true}}"
      empty-title="还没有合作会话"
      empty-description="在合作广场找到合适伙伴后，可以直接开始沟通"
      action-text="去合作广场"
      bind:action="openPlaza"
    ></data-state>
  </view>
  </block>
</view>
<tab-bar active="messages"></tab-bar>
