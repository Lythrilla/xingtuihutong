<view class="page-shell home-page">
  <page-header title="早上好，星光音乐" subtitle="{{headerSubtitle}}"></page-header>

  <view class="summary card">
    <view class="summary-head">
      <text>今日概览</text>
      <text class="summary-date">7月10日 · 周五</text>
    </view>
    <view class="metric-row">
      <view class="metric" wx:for="{{metrics}}" wx:key="label">
        <text class="metric-value">{{item.value}}</text>
        <text class="metric-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="ai-banner" bindtap="openAI">
    <view class="ai-glow"></view>
    <view class="ai-copy">
      <view class="ai-label">AI 智能经纪</view>
      <view class="ai-title">发现更适合你的合作伙伴</view>
      <view class="ai-desc">基于作品风格与历史表现实时推荐</view>
      <view class="ai-link">查看今日方案 →</view>
    </view>
    <image class="ai-image" src="/assets/images/ai-orb.png" mode="aspectFill"></image>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">为你推荐</text>
      <text class="section-action" bindtap="openAI">查看全部</text>
    </view>
    <view class="recommend-list card">
      <view class="recommend-item" wx:for="{{recommendations}}" wx:key="title">
        <view class="avatar {{item.avatarClass}}">{{item.avatar}}</view>
        <view class="recommend-main">
          <view class="recommend-line">
            <text class="recommend-title">{{item.title}}</text>
            <text class="score">匹配 {{item.score}}%</text>
          </view>
          <view class="recommend-subtitle">{{item.subtitle}}</view>
          <view class="recommend-foot">
            <text class="price">{{item.price}}</text>
            <text class="cooperate">查看合作</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">常用功能</text>
    </view>
    <view class="quick-grid">
      <view class="quick-card" bindtap="openMatch">
        <view class="quick-icon mint-bg">⌁</view>
        <text>推广匹配</text>
      </view>
      <view class="quick-card" bindtap="openPlaza">
        <view class="quick-icon blue-bg">◇</view>
        <text>合作管理</text>
      </view>
      <view class="quick-card" bindtap="openAI">
        <view class="quick-icon lilac-bg">✦</view>
        <text>数据中心</text>
      </view>
      <view class="quick-card">
        <view class="quick-icon gold-bg">￥</view>
        <text>收益结算</text>
      </view>
    </view>
  </view>
</view>
<tab-bar active="home"></tab-bar>
