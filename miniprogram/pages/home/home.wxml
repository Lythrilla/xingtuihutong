<view class="page-shell home-page">
  <page-header title="{{greeting}}，{{name}}" subtitle="{{headerSubtitle}}"></page-header>

  <data-state loading="{{loading}}" error="{{error}}" bind:action="loadHome"></data-state>

  <block wx:if="{{!loading && !error}}">
  <view class="summary card">
    <view class="summary-head">
      <text>今日概览</text>
      <text class="summary-date">{{todayLabel}}</text>
    </view>
    <view class="metric-row">
      <view class="metric" wx:for="{{metrics}}" wx:key="label">
        <text class="metric-value">{{item.value}}</text>
        <text class="metric-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="ai-banner" bindtap="openAI" hover-class="pressable">
    <view class="ai-copy">
      <view class="ai-label">AI 智能经纪</view>
      <view class="ai-title">发现更适合你的合作伙伴</view>
      <view class="ai-desc">基于作品风格与历史表现实时推荐</view>
      <view class="ai-link">
        <text>查看今日方案</text>
        <view class="link-arrow"></view>
      </view>
    </view>
    <view class="ai-visual">
      <image class="ai-image" src="/assets/images/ai-orb.webp" mode="aspectFit"></image>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">为你推荐</text>
      <text class="section-action" bindtap="openPlaza">查看全部</text>
    </view>
    <view class="recommend-list card" wx:if="{{recommendations.length}}">
      <view class="recommend-item" wx:for="{{recommendations}}" wx:key="id">
        <view class="avatar {{item.avatarClass}}">{{item.avatar}}</view>
        <view class="recommend-main">
          <view class="recommend-line">
            <text class="recommend-title">{{item.title}}</text>
            <text class="score">匹配 {{item.score}}%</text>
          </view>
          <view class="recommend-subtitle">{{item.subtitle}}</view>
          <view class="recommend-foot">
            <text class="price">{{item.price}}</text>
            <button
              class="cooperate"
              data-id="{{item.id}}"
              disabled="{{connectingId !== ''}}"
              loading="{{connectingId === item.id}}"
              bindtap="contactPartner"
            >{{connectingId === item.id ? '正在进入' : '沟通合作'}}</button>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="card inline-empty">暂无伙伴推荐，可前往合作广场主动发现。</view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">常用功能</text>
    </view>
    <view class="quick-grid">
      <view class="quick-card" bindtap="openMatch" hover-class="pressable">
        <view class="quick-icon mint-bg"><view class="ui-icon icon-target"></view></view>
        <text>推广匹配</text>
      </view>
      <view class="quick-card" bindtap="openPlaza" hover-class="pressable">
        <view class="quick-icon blue-bg"><view class="ui-icon icon-briefcase"></view></view>
        <text>合作广场</text>
      </view>
      <view class="quick-card" bindtap="openAI" hover-class="pressable">
        <view class="quick-icon lilac-bg"><view class="ui-icon icon-chart"></view></view>
        <text>推广方案</text>
      </view>
      <view class="quick-card" bindtap="openProfile" hover-class="pressable">
        <view class="quick-icon gold-bg"><view class="ui-icon icon-wallet"></view></view>
        <text>收益结算</text>
      </view>
    </view>
  </view>
  </block>
</view>
<tab-bar active="home"></tab-bar>
