<view class="page-shell">
  <page-header
    title="{{greeting}}，{{name || (isCreator ? '创作者' : '推广伙伴')}}"
    subtitle="{{headerSubtitle}}"
  ></page-header>

  <data-state loading="{{loading}}" error="{{error}}" bind:action="retry"></data-state>

  <block wx:if="{{!loading && !error}}">

    <view wx:if="{{isApproved}}" class="hero-card role-hero {{isCreator ? 'creator' : 'provider'}}" bindtap="openPrimary" hover-class="pressable">
      <view class="hero-card-glass"></view>
      <view class="hero-grid"></view>
      <view class="hero-orb-wrap">
        <view class="hero-orb-halo"></view>
        <image class="hero-orb" src="/assets/images/ai-illustration.png" mode="aspectFit"></image>
      </view>
      <view class="hero-copy">
        <view class="hero-title">
          <text>{{isCreator ? '为你的作品' : '发现真实创作者'}}</text>
          <text>{{isCreator ? '找到合适推广方' : '承接适合的项目'}}</text>
        </view>
        <view class="hero-desc">{{isCreator ? '选择已审核作品、推广方向与预算' : '只展示审核通过的创作者与作品信息'}}</view>
        <view class="hero-action">{{isCreator ? '发布推广需求' : '查看创作者项目'}} →</view>
      </view>
    </view>

    <view wx:if="{{isApproved}}" class="section">
      <view class="section-head">
        <text class="section-title">{{isCreator ? '已入驻推广方' : '已认证创作者'}}</text>
        <text class="section-action" bindtap="openPlaza">更多 ></text>
      </view>

      <view class="recommend-list" wx:if="{{recommendations.length}}">
        <view class="recommend-item" wx:for="{{recommendations}}" wx:key="id">
          <image
            wx:if="{{item.avatarIsImage}}"
            class="recommend-avatar"
            src="{{item.avatar}}"
            mode="aspectFill"
          ></image>
          <view wx:else class="recommend-avatar {{item.avatarClass}}">{{item.avatar}}</view>
          <view class="recommend-main">
            <view class="recommend-head">
              <text class="recommend-title">{{item.title}}</text>
              <view class="pill" wx:if="{{item.preferred || item.verified}}">{{isCreator ? '平台已审核' : '创作者已认证'}}</view>
            </view>
            <view class="recommend-subtitle">{{item.subtitle}}</view>
          </view>
          <view class="cooperate" data-id="{{item.id}}" bindtap="openPartner">{{isCreator ? '查看推广' : '查看项目'}}</view>
        </view>
      </view>
      <view wx:else class="inline-empty">
        {{isCreator ? '暂无已审核推广方，平台不会用虚拟资料参与匹配。' : '暂无已认证创作者项目，可稍后再来查看。'}}
      </view>
    </view>

    <view wx:else class="card onboarding-guide">
      <view class="guide-title">合作开始前，需要先完成 3 步</view>
      <view class="guide-row"><text>1</text><view><view class="guide-row-title">填写真实资料</view><view class="guide-row-desc">{{isCreator ? '创作者身份、代表作品与主页链接' : '团队主体、推广能力与合作预算'}}</view></view></view>
      <view class="guide-row"><text>2</text><view><view class="guide-row-title">平台审核</view><view class="guide-row-desc">审核通过前不进入广场，不参与匹配</view></view></view>
      <view class="guide-row"><text>3</text><view><view class="guide-row-title">进入专属工作台</view><view class="guide-row-desc">{{isCreator ? '发布推广需求并联系推广方' : '发现创作者项目并发起合作'}}</view></view></view>
      <button class="btn-primary" style="margin-top: 36rpx !important;" bindtap="openOnboarding">{{onboardingStatus === 'pending' ? '查看审核进度' : '完善入驻资料'}}</button>
    </view>
  </block>
</view>
<tab-bar active="home"></tab-bar>
