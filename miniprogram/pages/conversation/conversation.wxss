page {
  height: 100%;
  background: #f4f7f7;
}

.page {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.messages {
  flex: 1;
  box-sizing: border-box;
  padding: 28rpx;
}

.message-row {
  display: flex;
  margin-bottom: 20rpx;
}

.message-row.mine {
  justify-content: flex-end;
}

.message {
  max-width: 74%;
  padding: 18rpx 22rpx 14rpx;
  color: #29393e;
  font-size: 28rpx;
  line-height: 1.5;
  background: #ffffff;
  border: 1rpx solid #e1e8e9;
  border-radius: 18rpx;
}

.mine .message {
  color: #ffffff;
  background: #167f74;
  border-color: #167f74;
}

.time {
  display: block;
  margin-top: 8rpx;
  color: #91a0a5;
  font-size: 20rpx;
}

.mine .time {
  color: rgba(255, 255, 255, 0.72);
}

.composer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #dfe7e8;
}

.composer input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f1f5f5;
  border-radius: 14rpx;
}

.composer button {
  width: 120rpx;
  height: 76rpx;
  margin: 0;
  color: #ffffff;
  font-size: 27rpx;
  line-height: 76rpx;
  background: #167f74;
  border-radius: 14rpx;
}

.composer button::after {
  border: 0;
}
