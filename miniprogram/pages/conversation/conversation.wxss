page {
  height: 100%;
  background:
    linear-gradient(180deg, rgba(214, 241, 236, 0.32), rgba(246, 247, 249, 0) 340rpx),
    #f6f7f9;
}

.page {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.conversation-status {
  flex: none;
  padding: 13rpx 24rpx;
  color: #718287;
  font-size: 21rpx;
  text-align: center;
  background: rgba(234, 246, 243, 0.82);
  border-top: 1rpx solid rgba(23, 135, 123, 0.06);
  border-bottom: 1rpx solid rgba(23, 135, 123, 0.1);
}

.messages {
  flex: 1;
  box-sizing: border-box;
  padding: 28rpx 24rpx;
}

.conversation-empty {
  max-width: 560rpx;
  margin: 120rpx auto 0;
  padding: 38rpx 32rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(38, 64, 71, 0.08);
  border-radius: 14rpx;
  box-shadow: 0 12rpx 32rpx rgba(30, 51, 58, 0.06);
}

.empty-title {
  color: #293d42;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-description {
  margin-top: 12rpx;
  color: #839297;
  font-size: 23rpx;
  line-height: 1.55;
}

.message-row {
  display: flex;
  margin-bottom: 18rpx;
}

.message-row.mine {
  justify-content: flex-end;
}

.message {
  max-width: 74%;
  padding: 18rpx 22rpx 14rpx;
  color: #293d42;
  font-size: 27rpx;
  line-height: 1.5;
  background: #ffffff;
  border: 1rpx solid rgba(38, 64, 71, 0.08);
  border-radius: 12rpx 12rpx 12rpx 4rpx;
  box-shadow: 0 5rpx 16rpx rgba(30, 51, 58, 0.045);
}

.mine .message {
  color: #ffffff;
  background: linear-gradient(135deg, #17877b, #22a390);
  border-color: transparent;
  border-radius: 12rpx 12rpx 4rpx 12rpx;
  box-shadow: 0 7rpx 18rpx rgba(23, 135, 123, 0.14);
}

.time {
  display: block;
  margin-top: 8rpx;
  color: #91a0a5;
  font-size: 20rpx;
}

.mine .time {
  color: rgba(255, 255, 255, 0.72);
}

.composer {
  display: flex;
  gap: 14rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(38, 64, 71, 0.08);
}

.composer input {
  min-width: 0;
  flex: 1;
  height: 76rpx;
  padding: 0 22rpx;
  color: #293d42;
  font-size: 27rpx;
  background: #f2f6f5;
  border: 1rpx solid #e2eaea;
  border-radius: 11rpx;
}

.composer button {
  width: 120rpx;
  height: 76rpx;
  margin: 0;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 76rpx;
  background: linear-gradient(135deg, #17877b, #22a390);
  border-radius: 11rpx;
}

.composer button[disabled] {
  color: #98a3a8;
  background: #e5eaeb;
}

.composer button::after {
  border: 0;
}
