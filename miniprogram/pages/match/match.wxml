<view class="page-shell match-page">
  <page-header title="推广匹配" subtitle="选择歌曲与推广对象，AI 为你智能组局"></page-header>

  <data-state loading="{{loading}}" error="{{error}}" bind:action="loadOptions"></data-state>

  <block wx:if="{{!loading && !error}}">
  <data-state
    wx:if="{{!songs.length || !targets.length || !budgets.length}}"
    empty="{{true}}"
    empty-title="匹配资料还未准备好"
    empty-description="曲库、推广对象或预算配置暂不可用"
    action-text="重新加载"
    bind:action="loadOptions"
  ></data-state>

  <block wx:else>
  <view class="steps">
    <view class="step {{selectedSongId ? 'active done' : 'active'}}">
      <view class="step-number">1</view>
      <text>选择歌曲</text>
    </view>
    <view class="step-line {{selectedSongId ? 'active' : ''}}"></view>
    <view class="step {{selectedSongId ? 'active' : ''}} {{selectedTargets.length ? 'done' : ''}}">
      <view class="step-number">2</view>
      <text>推广对象</text>
    </view>
    <view class="step-line {{selectedTargets.length ? 'active' : ''}}"></view>
    <view class="step {{canSubmit ? 'active' : ''}}">
      <view class="step-number">3</view>
      <text>智能匹配</text>
    </view>
  </view>

  <view class="form-section card">
    <view class="form-title">选择要推广的歌曲</view>
    <view class="form-desc">从已入驻版权曲库中选择</view>
    <scroll-view class="song-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="song-row">
        <view
          wx:for="{{songs}}"
          wx:key="id"
          class="song-card {{selectedSongId === item.id ? 'selected' : ''}}"
          data-id="{{item.id}}"
          bindtap="chooseSong"
        >
          <view class="song-cover {{item.coverClass}}">
            <view class="disc"><view class="disc-center"></view></view>
          </view>
          <view class="song-name">{{item.name}}</view>
          <view class="song-artist">{{item.artist}}</view>
          <view class="song-check">✓</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="form-section card">
    <view class="form-title">希望由谁来推广？</view>
    <view class="form-desc">可多选，AI 会组合最优推广阵容</view>
    <view class="target-grid">
      <view
        wx:for="{{targets}}"
        wx:key="key"
        class="target-card {{item.selected ? 'selected' : ''}}"
        data-key="{{item.key}}"
        bindtap="toggleTarget"
      >
        <view class="target-icon"><view class="ui-icon icon-{{item.iconClass}}"></view></view>
        <view class="target-title">{{item.title}}</view>
        <view class="target-desc">{{item.description}}</view>
      </view>
    </view>
  </view>

  <view class="form-section card">
    <view class="form-title">合作预算</view>
    <view class="form-desc">用于筛选适配的服务方与推广方案</view>
    <view class="budget-list">
      <view
        wx:for="{{budgets}}"
        wx:key="id"
        class="budget {{selectedBudgetId === item.id ? 'selected' : ''}}"
        data-id="{{item.id}}"
        bindtap="chooseBudget"
      >
        <view class="radio"></view>
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="selection-summary">{{selectionSummary}}</view>
  <button
    class="primary-button match-button"
    disabled="{{!canSubmit || isSubmitting}}"
    loading="{{isSubmitting}}"
    bindtap="startMatching"
  >
    <text>{{isSubmitting ? '正在生成推荐' : '开始 AI 智能匹配'}}</text>
    <view class="ui-icon icon-spark button-icon"></view>
  </button>
  </block>
  </block>
</view>
<tab-bar active="match"></tab-bar>
