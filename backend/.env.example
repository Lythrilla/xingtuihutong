DATABASE_URL=sqlite://data/xingtuihutong.db
# 本机调试使用 127.0.0.1:3000；真机局域网调试可改为 0.0.0.0:3000
BIND_ADDRESS=127.0.0.1:3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
ALLOWED_ORIGIN=*

# OpenAI-compatible Chat Completions endpoint. Leave empty to use the local
# deterministic database-tool fallback without calling a model.
AGENT_MODEL_API_URL=
AGENT_MODEL_API_KEY=
AGENT_MODEL_TIMEOUT_SECS=60
